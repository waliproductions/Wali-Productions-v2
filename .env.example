# Copy to .env.local for local development and configure per environment.

# Public site URL (used by metadata / future SEO).
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Admin portal authentication (required — /admin routes are inaccessible without these)
# ADMIN_USERNAME=admin
# Generate hash: node -e "require('bcryptjs').hash('your-password', 12).then(h => console.log(h))"
# ADMIN_PASSWORD_HASH=
# Generate secret: openssl rand -base64 32
# SESSION_SECRET=

# Contact form email delivery
# Hostinger Email SMTP settings:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@your-domain.com
# SMTP_PASS=your-hostinger-email-password
# CONTACT_TO_EMAIL=your-email@your-domain.com
# CONTACT_FROM_EMAIL=your-email@your-domain.com

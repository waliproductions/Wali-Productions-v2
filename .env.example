# Wali Productions LLC — Environment Variable Reference
# Copy to .env.local for local development. Never commit .env.local.

# ─── REQUIRED: Admin Portal Authentication ────────────────────────────────────
# All three variables are required. /admin is inaccessible without them.

# Admin login username (plaintext)
ADMIN_USERNAME=admin

# bcryptjs hash of the admin password. Cost factor 12 recommended.
# Generate: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# iron-session encryption key. Must be at least 32 characters.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# ─── REQUIRED: Email Delivery (Contact Form) ──────────────────────────────────
# Used by /api/contact to deliver contact form submissions via SMTP.

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@waliproductions.com
SMTP_PASS=

# Where contact form submissions are sent
CONTACT_TO_EMAIL=waliproductionsllc@gmail.com

# The From address on outgoing contact form emails
CONTACT_FROM_EMAIL=noreply@waliproductions.com

# ─── OPTIONAL: Site Configuration ─────────────────────────────────────────────
# Used for SEO metadata, OG image URLs, and canonical links.
# Set to your production domain when deploying.

NEXT_PUBLIC_SITE_URL=https://waliproductions.com
